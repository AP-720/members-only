<html>
	<%- include("./partials/head.ejs") %>
	<div class="content-container">
		<div class="nav-bar page-title">
			<h1><%= title %></h1>
			<a href="/">Home</a>
		</div>
		<%- include("./partials/errors.ejs") %>
		<div class="advanced-form-container">
			<form action="/become-member" method="post">
				<h2>Become Member</h2>
				<label for="membership_code"
					>Membership Code:
					<input name="membership_code" id="membership_code"
					<% if (currentUser.membership_status) { %> disabled
					<% } %> />
				</label>
				<button type="submit">Enter</button>
			</form>
			<% if(currentUser.membership_status) { %>
			<form action="/become-admin" method="post">
				<h2>Become Admin</h2>
				<label for="admin_code"
					>Admin Code:
					<input name="admin_code" id="admin_code" />
				</label>
				<button type="submit">Enter</button>
			</form>
			<% } %>
		</div>
	</div>
</html>